# House of Prax environment schema
# This file declares variable names only. Real secrets live in Vercel environment variables.
# Keep this file in sync with docs/ENVIRONMENT_AND_VERCEL.md.

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# App auth and sessions
APP_AUTH_MODE=email_otp
APP_SESSION_SECRET=
AUTH_DEV_OTP_CODE=111111
ADMIN_EMAILS=halodyrane@gmail.com

# AWS core
AWS_REGION=
AWS_ACCOUNT_ID=
AWS_ROLE_ARN=
AWS_RESOURCE_ARN=

# Aurora PostgreSQL
# Primary Vercel runtime path: PG* variables + AWS_REGION + AWS_ROLE_ARN using OIDC and RDS IAM auth.
# Direct URL or password access remains supported for local tooling and emergency/manual access.
DATABASE_URL=
DATABASE_DIRECT_URL=
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=require

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=
COGNITO_REGION=

# S3
S3_BUCKET_NAME=
S3_BUCKET_REGION=
S3_UPLOAD_PREFIX=uploads

# Email - choose one provider path at launch
# Resend uses onboarding@resend.dev as a local-development fallback only.
# Production should set RESEND_FROM_EMAIL to a verified sender on your domain.
SES_FROM_EMAIL=
SES_CONFIGURATION_SET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Banking and operations
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_NAME=
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_INSTRUCTIONS=Include your order number as the transfer reference.

# Optional CI or automation
CRON_SECRET=
VERCEL_ACCESS_TOKEN=
